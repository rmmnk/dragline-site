/*
  # Prevent clickjacking — no iframes allowed
  X-Frame-Options: DENY

  # Prevent MIME-type sniffing attacks
  X-Content-Type-Options: nosniff

  # Don't leak referrer to external domains
  Referrer-Policy: strict-origin-when-cross-origin

  # Disable browser features not used by this site
  Permissions-Policy: accelerometer=(), camera=(), display-capture=(), geolocation=(), gyroscope=(), magnetometer=(), microphone=(), payment=(), usb=(), xr-spatial-tracking=()

  # HSTS — force HTTPS for 2 years, include subdomains, submit to preload list
  Strict-Transport-Security: max-age=63072000; includeSubDomains; preload

  # Isolate this page's browsing context
  Cross-Origin-Opener-Policy: same-origin

  # Restrict cross-origin resource sharing
  Cross-Origin-Resource-Policy: same-origin

  # Content Security Policy
  # - No external scripts, fonts, or images
  # - unsafe-inline required: Astro inlines scoped CSS; JSON-LD is in script tags (data, not executable)
  # - frame-ancestors: none = belt + suspenders with X-Frame-Options
  Content-Security-Policy: default-src 'none'; script-src 'unsafe-inline'; style-src 'unsafe-inline'; img-src 'self' data:; font-src 'self'; base-uri 'self'; form-action 'none'; frame-ancestors 'none'

# Cache static assets aggressively — Astro fingerprints filenames
/_astro/*
  Cache-Control: public, max-age=31536000, immutable

# Never cache HTML — always fresh
/*.html
  Cache-Control: no-cache

/index.html
  Cache-Control: no-cache
