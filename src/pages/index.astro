---
const jsonLd = {
  "@context": "https://schema.org",
  "@type": "Organization",
  "name": "Dragline",
  "url": "https://dragline.io",
  "description": "Data Mining infrastructure and crypto-native transaction rails for the agent economy."
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="Dragline — Data Mining infrastructure and crypto-native transactions for AI agents. Coming soon." />
    <title>Dragline</title>
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
    <style>
      * { box-sizing: border-box; margin: 0; padding: 0; }
      body {
        background: #0a0a0a;
        color: #f5f5f5;
        font-family: 'Courier New', Courier, monospace;
        display: flex;
        align-items: center;
        justify-content: center;
        min-height: 100vh;
        padding: 2rem;
      }
      main { text-align: center; }
      h1 {
        font-size: 1.4rem;
        font-weight: normal;
        letter-spacing: 0.15em;
        text-transform: uppercase;
        margin-bottom: 1.5rem;
      }
      p { color: #888; font-size: 0.9rem; line-height: 1.6; }
      a { color: #e8d5a3; text-decoration: none; }
    </style>
  </head>
  <body>
    <main>
      <h1>Dragline</h1>
      <p>Data Mining Infrastructure. Crypto-Native Transaction Rails.</p>
      <p style="margin-top: 2rem;">
        <a href="mailto:paul@dragline.io">paul@dragline.io</a>
      </p>
    </main>
  </body>
</html>
