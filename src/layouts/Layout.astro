---
interface Props {
  title: string;
  description: string;
  jsonLd?: object;
}

const { title, description, jsonLd } = Astro.props;

const org = {
  "@context": "https://schema.org",
  "@type": "Organization",
  "name": "Dragline",
  "url": "https://dragline.io",
  "description": "Data Mining infrastructure and crypto-native transaction rails for the agent economy."
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <link rel="sitemap" href="/sitemap-index.xml" />
    <script type="application/ld+json" set:html={JSON.stringify(org)} />
    {jsonLd && <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />}
    <style>
      :root {
        --black: #0a0a0a;
        --white: #f5f5f5;
        --gray: #888;
        --accent: #e8d5a3;
        --max: 720px;
      }
      * { box-sizing: border-box; margin: 0; padding: 0; }
      body {
        background: var(--black);
        color: var(--white);
        font-family: 'Courier New', Courier, monospace;
        font-size: 15px;
        line-height: 1.7;
        padding: 3rem 1.5rem;
      }
      main { max-width: var(--max); margin: 0 auto; }
      nav {
        display: flex;
        justify-content: space-between;
        align-items: baseline;
        margin-bottom: 4rem;
        border-bottom: 1px solid #222;
        padding-bottom: 1rem;
      }
      nav a { color: var(--white); text-decoration: none; }
      nav .wordmark { font-size: 1.1rem; letter-spacing: 0.15em; text-transform: uppercase; }
      nav .links a { color: var(--gray); margin-left: 2rem; font-size: 0.85rem; }
      nav .links a:hover { color: var(--white); }
      h1 { font-size: 1.6rem; font-weight: normal; letter-spacing: -0.01em; margin-bottom: 1rem; }
      h2 { font-size: 1rem; text-transform: uppercase; letter-spacing: 0.1em; color: var(--gray); margin: 2.5rem 0 0.75rem; }
      p { color: #ccc; margin-bottom: 1rem; }
      a { color: var(--accent); text-decoration: none; }
      a:hover { text-decoration: underline; }
      .tagline { color: var(--gray); font-size: 0.9rem; margin-bottom: 3rem; }
      footer {
        margin-top: 5rem;
        padding-top: 1rem;
        border-top: 1px solid #222;
        color: var(--gray);
        font-size: 0.8rem;
      }
    </style>
  </head>
  <body>
    <main>
      <nav>
        <a href="/" class="wordmark">Dragline</a>
        <div class="links">
          <a href="/products/stratumgate">StratumGate</a>
          <a href="/about">About</a>
        </div>
      </nav>
      <slot />
      <footer>
        <p>© {new Date().getFullYear()} Dragline. Data Mining Infrastructure. Crypto-Native Transaction Rails.</p>
      </footer>
    </main>
  </body>
</html>
